{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "IamRoleManagement",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:GetRole",
        "iam:PutRolePolicy",
        "iam:GetRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:DeleteRole",
        "iam:TagRole",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies"
      ],
      "Resource": "arn:aws:iam::*:role/redshift-mcp-lambda-execution-role"
    },
    {
      "Sid": "IamDevOpsAgentRoleManagement",
      "Comment": "Only needed when deploying with CreateDevOpsAgentRole=true. Update the resource name if you set a custom DevOpsAgentRoleName.",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:GetRole",
        "iam:PutRolePolicy",
        "iam:GetRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:DeleteRole",
        "iam:TagRole",
        "iam:ListRolePolicies"
      ],
      "Resource": "arn:aws:iam::*:role/DevOpsAgentRole-Redshift-support-specialist"
    },
    {
      "Sid": "PassRoleToLambda",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::*:role/redshift-mcp-lambda-execution-role",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "lambda.amazonaws.com"
        }
      }
    },
    {
      "Sid": "GrantCallerRoleAccess",
      "Comment": "Only needed when deploy.sh's third argument (caller-role-arn) is used, or when manually re-running the printed put-role-policy command. Grants the deployer permission to attach an inline policy to an externally-owned caller role (e.g. a DevOps Agent Agent Space role) so it can invoke the API Gateway endpoint. Not scoped to a specific role name since the caller role is provided at deploy time and may vary. If you know the caller role ahead of time, replace this Resource with its specific ARN for tighter scoping.",
      "Effect": "Allow",
      "Action": "iam:PutRolePolicy",
      "Resource": "*"
    },
    {
      "Sid": "LambdaFunctionManagement",
      "Effect": "Allow",
      "Action": [
        "lambda:CreateFunction",
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration",
        "lambda:GetFunction",
        "lambda:DeleteFunction",
        "lambda:TagResource",
        "lambda:AddPermission",
        "lambda:RemovePermission",
        "lambda:GetPolicy"
      ],
      "Resource": "arn:aws:lambda:*:*:function:redshift-mcp-proxy-zip*"
    },
    {
      "Sid": "ApiGatewayManagement",
      "Comment": "Needed by deployment/deploy.sh (Option B) to create/reuse the REST API, /mcp resource, method, integration, and stage. Scoped to apigateway:* actions rather than per-resource ARNs because API Gateway's ARN format for these management APIs does not support resource-level restriction by API name.",
      "Effect": "Allow",
      "Action": [
        "apigateway:GET",
        "apigateway:POST",
        "apigateway:PUT",
        "apigateway:PATCH",
        "apigateway:DELETE"
      ],
      "Resource": "*"
    },
    {
      "Sid": "StsIdentity",
      "Effect": "Allow",
      "Action": "sts:GetCallerIdentity",
      "Resource": "*"
    },
    {
      "Sid": "SamCloudFormationStack",
      "Effect": "Allow",
      "Action": [
        "cloudformation:CreateChangeSet",
        "cloudformation:DescribeChangeSet",
        "cloudformation:ExecuteChangeSet",
        "cloudformation:CreateStack",
        "cloudformation:UpdateStack",
        "cloudformation:DeleteStack",
        "cloudformation:DescribeStacks",
        "cloudformation:DescribeStackEvents",
        "cloudformation:GetTemplateSummary"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SamManagedArtifactBucket",
      "Comment": "sam deploy --resolve-s3 creates/uses a managed bucket named aws-sam-cli-managed-* for deployment artifacts.",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:PutObject",
        "s3:GetObject",
        "s3:GetBucketLocation",
        "s3:ListBucket",
        "s3:PutBucketPolicy",
        "s3:PutEncryptionConfiguration"
      ],
      "Resource": [
        "arn:aws:s3:::aws-sam-cli-managed-*",
        "arn:aws:s3:::aws-sam-cli-managed-*/*"
      ]
    }
  ]
}
